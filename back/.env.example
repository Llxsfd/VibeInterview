# ---------------------------------------------------------------------------
# 后端环境变量示例文件 (.env.example)
# 这个文件应该被提交到 Github 上，用来告诉其他开发者需要哪些环境变量
# 开发者在本地部署时，需要复制此文件并重命名为 .env，然后填入真实的敏感信息
# ---------------------------------------------------------------------------

# 系统基础配置
PROJECT_NAME="Smart Interview Platform"
ENVIRONMENT="development"

# 数据库连接 (敏感信息，本地 .env 填写实际密码)
POSTGRES_USER="your_db_user"
POSTGRES_PASSWORD="your_db_password"
POSTGRES_HOST="localhost"
POSTGRES_PORT="5432"
POSTGRES_DB="smart_interview_db"
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}"

# Redis 缓存与队列连接
REDIS_URL="redis://localhost:6379/0"

# 大模型 API 密钥 (如 OpenAI, DeepSeek 等)
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
DEEPSEEK_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# 安全相关密钥 (JWT 生成密钥等)
SECRET_KEY="your_super_secret_key_here"
